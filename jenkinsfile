pipeline {
    agent any

    stages {

        stage("Code") {
            steps {
                git 'https://github.com/Vijay0430/python-code-library-app.git'
            }
        }

        stage("CQA") {
            steps {
                script {
                    def scannerHome = tool 'sonar'
                    withSonarQubeEnv('mysonar') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=python-library-app \
                        -Dsonar.projectName=python-library-app \
                        -Dsonar.sources=.
                        """
                    }
                }
            }
        }
        
        stage('build') {
            steps {
                sh 'docker build -t frontendimage ./'
                sh 'docker build -t dbimage ./database'
                sh 'docker build -t authimage ./auth'
                sh 'docker build -t bookimage ./book'
                sh 'docker build -t borrowimage ./borrow'
            }
        }
        
        stage ('scan') {
            steps {
                sh 'trivy image frontendimage'
                sh 'trivy image dbimage'
                sh 'trivy image authimage'
                sh 'trivy image bookimage'
                sh 'trivy image borrowimage'
            }
        }
        
        stage('tag') {
            steps {
                sh 'docker tag frontendimage suranagavijay63/dockerrepo:frontendimage'
                sh 'docker tag dbimage suranagavijay63/dockerrepo:dbimage'
                sh 'docker tag bookimage suranagavijay63/dockerrepo:bookimage'
                sh 'docker tag authimage suranagavijay63/dockerrepo:authimage'
                sh 'docker tag borrowimage suranagavijay63/dockerrepo:borrowimage'
            }
        }
        
        stage('push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'dockerhub', url: 'https://index.docker.io/v1/') {
                        sh 'docker push suranagavijay63/dockerrepo:frontendimage'
                        sh 'docker push suranagavijay63/dockerrepo:dbimage'
                        sh 'docker push suranagavijay63/dockerrepo:authimage'
                        sh 'docker push suranagavijay63/dockerrepo:bookimage'
                        sh 'docker push suranagavijay63/dockerrepo:borrowimage'
                    }
                }
            }
        }
        
        stage ('deploy') {
            steps {
                sh 'docker-compose up -d'
                
            }
        }

    }
}
